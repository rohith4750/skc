{
  "name": "catering-management",
  "version": "1.0.0",
  "main": "main.js",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "electron-dev": "electron .",
    "electron-pack": "electron-builder --dir",
    "electron-dist": "electron-builder"
  },
  "dependencies": {
    "@emailjs/browser": "^4.4.1",
    "@hello-pangea/dnd": "^18.0.1",
    "@prisma/client": "^5.17.0",
    "@types/nodemailer": "^7.0.5",
    "axios": "^1.13.6",
    "bcryptjs": "^3.0.3",
    "html2canvas": "^1.4.1",
    "jose": "^6.1.3",
    "jspdf": "^4.0.0",
    "next": "^14.2.0",
    "nodemailer": "^7.0.12",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-floating-whatsapp": "^5.0.8",
    "react-icons": "^4.12.0",
    "resend": "^6.7.0",
    "sonner": "^2.0.7",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jspdf": "^1.3.3",
    "@types/node": "^20.10.6",
    "@types/pako": "^2.0.4",
    "@types/react": "^18.2.46",
    "@types/react-dom": "^18.2.18",
    "@types/uuid": "^9.0.1",
    "autoprefixer": "^10.4.16",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^8.56.0",
    "eslint-config-next": "14.0.4",
    "postcss": "^8.4.32",
    "prisma": "^5.17.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.3"
  },
  "build": {
    "appId": "com.skccaterers.app",
    "productName": "SKC Caterers",
    "copyright": "Copyright © 2026 SKC Caterers",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "public/images/logo-dark.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SKC Caterers"
    },
    "files": [
      "main.js",
      "preload.js",
      "offline.html",
      "public/images/logo-dark.png",
      "node_modules/**/*"
    ],
    "publish": [
      {
        "provider": "generic",
        "url": "https://www.skccaterers.in/download"
      }
    ]
  }
}
